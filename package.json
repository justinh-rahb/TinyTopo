{
  "name": "tinytopo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Turn any place on Earth into a 3D-printable model, entirely in your browser.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.17.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "osmtogeojson": "^3.0.0-beta.5",
    "three": "^0.166.0"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/leaflet": "^1.9.12",
    "@types/three": "^0.166.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
